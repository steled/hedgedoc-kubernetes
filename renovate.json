{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    "github>steled/renovate-config"
  ],

  "timezone": "Europe/Berlin",

  "labels": ["renovate", "dependencies"],

  "helmv3": {
    "managerFilePatterns": [
      "/^charts/[^/]+/Chart\.yaml$/"
    ]
  },

  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^charts/[^/]+/values\.yaml$/"
      ],
      "matchStrings": [
        "repository:\\s*(?<depName>[^\\s#]+)\\n[^\\n]*?tag:\\s*[\"']?(?<currentValue>[^\"'\\s#\\n]+)[\"']?"
      ],
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    }
  ],

  "packageRules": [
    {
      "matchManagers": ["custom.regex"],
      "matchPackageNames": ["quay.io/hedgedoc/hedgedoc"],
      "groupName": "hedgedoc image",
      "commitMessageTopic": "hedgedoc image to {{newVersion}}"
    },

    {
      "matchManagers": ["helmv3"],
      "matchPackageNames": ["postgresql"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "bitnami/postgresql sub-chart",
      "automerge": false
    },

    {
      "matchManagers": ["helmv3"],
      "matchUpdateTypes": ["major"],
      "labels": ["renovate", "dependencies", "breaking-change"],
      "automerge": false
    },

    {
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["patch"],
      "automerge": true,
      "automergeType": "pr"
    }
  ]
}
